# Copy this file to `.env` (and `.env.production`, etc.) and fill in real values.
# Vite only exposes variables prefixed with VITE_ to the client bundle.
# NEVER put secrets (private keys, DB creds) here — this is shipped to the browser.

# Base URL of the backend API (include the /api/v1 prefix)
VITE_API_BASE_URL=https://tgvahan.com/api/v1

# App metadata
VITE_APP_NAME=TGVAHAN
VITE_APP_ENV=development
